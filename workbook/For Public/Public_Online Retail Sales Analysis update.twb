      <column caption='Visit Count Bin' datatype='string' name='[Calculation_0204245964599296]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [visit_count] = 1 THEN &quot;1 visit&quot;&#13;&#10;ELSEIF [visit_count] &lt;= 3 THEN &quot;2-3 visits&quot;&#13;&#10;ELSEIF [visit_count] &lt;= 6 THEN &quot;4-6 visits&quot;&#13;&#10;ELSEIF [visit_count] &lt;= 10 THEN &quot;7-10 visits&quot;&#13;&#10;ELSEIF [visit_count] &lt;= 20 THEN &quot;11-20 visits&quot;&#13;&#10;ELSEIF [visit_count] &lt;= 50 THEN &quot;21-50 visits&quot;&#13;&#10;ELSE &quot;50+ visits&quot;&#13;&#10;END' />
      </column>
      <column caption='Customer Count' datatype='integer' name='[Calculation_1349661743374336]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([CustomerID])' />
      </column>
      <column caption='Avg. Spending' datatype='real' name='[Calculation_1349661775036419]' role='measure' type='quantitative'>
